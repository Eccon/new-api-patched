+function formatCacheReadRate(
+  cacheTokens: number,
+  promptTokens: number,
+  other: LogOtherData | null
+): string {
+  const cacheReadTokens = Number(cacheTokens)
+  const inputTokens = Number(promptTokens)
+  const denominator =
+    other?.claude === true ? inputTokens + cacheReadTokens : inputTokens
+  if (
+    !Number.isFinite(cacheReadTokens) ||
+    !Number.isFinite(denominator) ||
+    cacheReadTokens <= 0 ||
+    denominator <= 0
+  ) {
+    return ''
+  }
+
+  const rate = (cacheReadTokens / denominator) * 100
+  const fixed = rate.toFixed(1)
+  return fixed.endsWith('.0') ? `${Math.round(rate)}%` : `${fixed}%`
+}
