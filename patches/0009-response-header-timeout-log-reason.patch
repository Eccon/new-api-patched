+func isResponseHeaderTimeout(err error) bool {
+	if err == nil {
+		return false
+	}
+	msg := strings.ToLower(err.Error())
+	return strings.Contains(msg, "timeout awaiting response headers") ||
+		strings.Contains(msg, "response header timeout")
+}
