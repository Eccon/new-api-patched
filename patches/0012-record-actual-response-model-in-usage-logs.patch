+	}
+
+	requestModel := strings.TrimSpace(relayInfo.OriginModelName)
+	mappedModel := strings.TrimSpace(relayInfo.UpstreamModelName)
+	responseModel := strings.TrimSpace(relayInfo.ResponseModelName)
+
+	if responseModel != "" && (responseModel != requestModel || (mappedModel != "" && responseModel != mappedModel)) {
+		other["response_model_name"] = responseModel
+		other["actual_model_name"] = responseModel
+		return
+	}
+
+	if relayInfo.IsModelMapped && mappedModel != "" && mappedModel != requestModel {
+		other["actual_model_name"] = mappedModel
+	}
+}
