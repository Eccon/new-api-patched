diff --git a/relay/channel/upstream_user_agent.go b/relay/channel/upstream_user_agent.go
new file mode 100644
index 0000000..9481a0b
--- /dev/null
+++ b/relay/channel/upstream_user_agent.go
@@ -0,0 +1,77 @@
+package channel
+
+import (
+	"fmt"
+	"net/http"
+	"strings"
+
+	"github.com/QuantumNous/new-api/common"
+	"github.com/QuantumNous/new-api/logger"
+	relaycommon "github.com/QuantumNous/new-api/relay/common"
+	"github.com/QuantumNous/new-api/types"
+
+	"github.com/gin-gonic/gin"
+)
+
+const netHTTPDefaultUserAgent = "Go-http-client/2.0"
+
+func configuredUpstreamUserAgent(info *relaycommon.RelayInfo) string {
+	if info == nil {
+		return ""
+	}
+
+	switch info.GetFinalRequestRelayFormat() {
+	case types.RelayFormatClaude:
+		return strings.TrimSpace(common.UpstreamUserAgentClaude)
+	case types.RelayFormatGemini:
+		return strings.TrimSpace(common.UpstreamUserAgentGemini)
+	case types.RelayFormatOpenAI,
+		types.RelayFormatOpenAIResponses,
+		types.RelayFormatOpenAIResponsesCompaction:
+		return strings.TrimSpace(common.UpstreamUserAgentOpenAI)
+	}
+	return ""
+}
+
+func incomingRequestUserAgent(c *gin.Context) string {
+	if c == nil || c.Request == nil {
+		return ""
+	}
+	return strings.TrimSpace(c.Request.UserAgent())
+}
+
+func applyDefaultUpstreamUserAgent(c *gin.Context, req *http.Request, info *relaycommon.RelayInfo) {
+	if req == nil || req.Header.Get("User-Agent") != "" {
+		return
+	}
+	if userAgent := configuredUpstreamUserAgent(info); userAgent != "" {
+		req.Header.Set("User-Agent", userAgent)
+		return
+	}
+	if userAgent := incomingRequestUserAgent(c); userAgent != "" {
+		req.Header.Set("User-Agent", userAgent)
+	}
+}
+
+func effectiveUpstreamUserAgent(req *http.Request) string {
+	if req == nil {
+		return ""
+	}
+	if _, ok := req.Header["User-Agent"]; ok {
+		return strings.TrimSpace(req.Header.Get("User-Agent"))
+	}
+	return netHTTPDefaultUserAgent
+}
+
+func logUpstreamUserAgent(c *gin.Context, req *http.Request) {
+	if req == nil {
+		return
+	}
+	requestUA := incomingRequestUserAgent(c)
+	upstreamUA := effectiveUpstreamUserAgent(req)
+	if requestUA != upstreamUA {
+		logger.LogInfo(c, fmt.Sprintf("user-agent rewrite: request=%q -> upstream=%q", requestUA, upstreamUA))
+		return
+	}
+	logger.LogInfo(c, fmt.Sprintf("user-agent passthrough: upstream=%q (same as request)", upstreamUA))
+}
