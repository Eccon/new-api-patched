+func configuredUpstreamUserAgent(info *common.RelayInfo) string {
+	if info == nil || info.ChannelMeta == nil {
+		return ""
+	}
+
+	switch info.ChannelType {
+	case channelconstant.ChannelTypeAnthropic:
+		return strings.TrimSpace(common2.UpstreamUserAgentClaude)
+	case channelconstant.ChannelTypeMoonshot:
+		if info.GetFinalRequestRelayFormat() == types.RelayFormatClaude {
+			return strings.TrimSpace(common2.UpstreamUserAgentClaude)
+		}
+		return strings.TrimSpace(common2.UpstreamUserAgentOpenAI)
+	case channelconstant.ChannelTypeGemini, channelconstant.ChannelTypeVertexAi, channelconstant.ChannelTypePaLM:
+		return strings.TrimSpace(common2.UpstreamUserAgentGemini)
+	}
+
+	if isOpenAIStyleChannelType(info.ChannelType) {
+		return strings.TrimSpace(common2.UpstreamUserAgentOpenAI)
+	}
+	return ""
+}
+
+func isOpenAIStyleChannelType(channelType int) bool {
+	switch channelType {
+	case channelconstant.ChannelTypeOpenAI,
+		channelconstant.ChannelTypeAzure,
+		channelconstant.ChannelTypeOpenAIMax,
+		channelconstant.ChannelTypeOhMyGPT,
+		channelconstant.ChannelTypeCustom,
+		channelconstant.ChannelTypeAILS,
+		channelconstant.ChannelTypeAIProxy,
+		channelconstant.ChannelTypeAPI2GPT,
+		channelconstant.ChannelTypeAIGC2D,
+		channelconstant.ChannelType360,
+		channelconstant.ChannelTypeOpenRouter,
+		channelconstant.ChannelTypeAIProxyLibrary,
+		channelconstant.ChannelTypeFastGPT,
+		channelconstant.ChannelTypePerplexity,
+		channelconstant.ChannelTypeLingYiWanWu,
+		channelconstant.ChannelTypeSiliconFlow,
+		channelconstant.ChannelTypeMistral,
+		channelconstant.ChannelTypeDeepSeek,
+		channelconstant.ChannelTypeMokaAI,
+		channelconstant.ChannelTypeVolcEngine,
+		channelconstant.ChannelTypeXinference,
+		channelconstant.ChannelTypeXai,
+		channelconstant.ChannelTypeSubmodel,
+		channelconstant.ChannelTypeSora,
+		channelconstant.ChannelTypeCodex:
+		return true
+	}
+	return false
+}
+
+func incomingRequestUserAgent(c *gin.Context) string {
+	if c == nil || c.Request == nil {
+		return ""
+	}
+	return strings.TrimSpace(c.Request.UserAgent())
+}
+
+func applyDefaultUpstreamUserAgent(c *gin.Context, req *http.Request, info *common.RelayInfo) {
+	if req == nil || req.Header.Get("User-Agent") != "" {
+		return
+	}
+	if userAgent := configuredUpstreamUserAgent(info); userAgent != "" {
+		req.Header.Set("User-Agent", userAgent)
+		return
+	}
+	if userAgent := incomingRequestUserAgent(c); userAgent != "" {
+		req.Header.Set("User-Agent", userAgent)
+	}
+}
