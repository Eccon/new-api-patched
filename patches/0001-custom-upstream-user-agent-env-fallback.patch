+func TestProcessHeaderOverrideSyncsUserAgentOverrideState(t *testing.T) {
+	gin.SetMode(gin.TestMode)
+	recorder := httptest.NewRecorder()
+	ctx, _ := gin.CreateTestContext(recorder)
+	ctx.Request = httptest.NewRequest(http.MethodPost, "/v1/chat/completions", nil)
+	ctx.Request.Header.Set("User-Agent", "client-ua")
+
+	withUserAgent := &relaycommon.RelayInfo{
+		ChannelMeta: &relaycommon.ChannelMeta{
+			HeadersOverride: map[string]any{
+				"User-Agent": "channel-a-ua",
+			},
+		},
+	}
+	headers, err := processHeaderOverride(withUserAgent, ctx)
+	require.NoError(t, err)
+	require.Equal(t, "channel-a-ua", headers["user-agent"])
+	require.True(t, upstreamUserAgentOverridden(ctx))
+
+	withoutUserAgent := &relaycommon.RelayInfo{
+		ChannelMeta: &relaycommon.ChannelMeta{
+			HeadersOverride: map[string]any{
+				"X-Test": "channel-b",
+			},
+		},
+	}
+	headers, err = processHeaderOverride(withoutUserAgent, ctx)
+	require.NoError(t, err)
+	require.Equal(t, "channel-b", headers["x-test"])
+	require.False(t, upstreamUserAgentOverridden(ctx))
+
+	passthroughUserAgent := &relaycommon.RelayInfo{
+		ChannelMeta: &relaycommon.ChannelMeta{
+			HeadersOverride: map[string]any{
+				"*": "",
+			},
+		},
+	}
+	headers, err = processHeaderOverride(passthroughUserAgent, ctx)
+	require.NoError(t, err)
+	require.Equal(t, "client-ua", headers["user-agent"])
+	require.True(t, upstreamUserAgentOverridden(ctx))
+
+	headers, err = processHeaderOverride(nil, ctx)
+	require.NoError(t, err)
+	require.Empty(t, headers)
+	require.False(t, upstreamUserAgentOverridden(ctx))
+}
+
+func TestApplyDefaultUpstreamUserAgentPriorityAfterStateSync(t *testing.T) {
+	gin.SetMode(gin.TestMode)
+	recorder := httptest.NewRecorder()
+	ctx, _ := gin.CreateTestContext(recorder)
+	ctx.Request = httptest.NewRequest(http.MethodPost, "/v1/chat/completions", nil)
+	ctx.Request.Header.Set("User-Agent", "client-ua")
+
+	previousOpenAIUserAgent := common.UpstreamUserAgentOpenAI
+	common.UpstreamUserAgentOpenAI = "env-ua"
+	t.Cleanup(func() {
+		common.UpstreamUserAgentOpenAI = previousOpenAIUserAgent
+	})
+
+	info := &relaycommon.RelayInfo{RelayFormat: types.RelayFormatOpenAI}
+
+	syncUpstreamUserAgentOverrideState(ctx, map[string]string{
+		"User-Agent": "channel-b-ua",
+	})
+	req := httptest.NewRequest(http.MethodPost, "https://example.com/v1/chat/completions", nil)
+	req.Header.Set("User-Agent", "channel-b-ua")
+	applyDefaultUpstreamUserAgent(ctx, req, info)
+	require.Equal(t, "channel-b-ua", req.Header.Get("User-Agent"))
+
+	syncUpstreamUserAgentOverrideState(ctx, map[string]string{})
+	req = httptest.NewRequest(http.MethodPost, "https://example.com/v1/chat/completions", nil)
+	applyDefaultUpstreamUserAgent(ctx, req, info)
+	require.Equal(t, "env-ua", req.Header.Get("User-Agent"))
+
+	req = httptest.NewRequest(http.MethodPost, "https://example.com/v1/chat/completions", nil)
+	req.Header.Set("User-Agent", "client-ua")
+	applyDefaultUpstreamUserAgent(ctx, req, info)
+	require.Equal(t, "env-ua", req.Header.Get("User-Agent"))
+
+	req = httptest.NewRequest(http.MethodPost, "https://example.com/v1/chat/completions", nil)
+	req.Header.Set("User-Agent", "adapter-ua")
+	applyDefaultUpstreamUserAgent(ctx, req, info)
+	require.Equal(t, "adapter-ua", req.Header.Get("User-Agent"))
+
+	common.UpstreamUserAgentOpenAI = ""
+	req = httptest.NewRequest(http.MethodPost, "https://example.com/v1/chat/completions", nil)
+	applyDefaultUpstreamUserAgent(ctx, req, info)
+	require.Equal(t, "client-ua", req.Header.Get("User-Agent"))
+}
