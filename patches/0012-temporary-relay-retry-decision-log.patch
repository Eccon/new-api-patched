+func ChannelAffinityRetryDebugString(c *gin.Context) string {
+	if c == nil {
+		return "affinity=none"
+	}
+
+	parts := make([]string, 0, 6)
+	if v, ok := c.Get(ginKeyChannelAffinitySkipRetry); ok {
+		if b, ok := v.(bool); ok {
+			parts = append(parts, fmt.Sprintf("affinity_context_skip=%t", b))
+		} else {
+			parts = append(parts, "affinity_context_skip=invalid")
+		}
+	} else {
+		parts = append(parts, "affinity_context_skip=unset")
+	}
+
+	meta, ok := getChannelAffinityMeta(c)
+	if !ok {
+		parts = append(parts, "affinity_meta=none")
+		return strings.Join(parts, " ")
+	}
+
+	parts = append(parts,
+		fmt.Sprintf("affinity_rule=%q", meta.RuleName),
+		fmt.Sprintf("affinity_meta_skip=%t", meta.SkipRetry),
+		fmt.Sprintf("affinity_group=%q", meta.UsingGroup),
+		fmt.Sprintf("affinity_model=%q", meta.ModelName),
+		fmt.Sprintf("affinity_key_fp=%q", meta.KeyFingerprint),
+		channelAffinityRuntimeRuleDebugString(meta.RuleName),
+		channelAffinityOptionRuleDebugString(meta.RuleName),
+	)
+	return strings.Join(parts, " ")
+}
+
+func channelAffinityRuntimeRuleDebugString(ruleName string) string {
+	setting := operation_setting.GetChannelAffinitySetting()
+	if setting == nil {
+		return "affinity_runtime_setting=nil"
+	}
+	for i, rule := range setting.Rules {
+		if rule.Name == ruleName {
+			return fmt.Sprintf("affinity_runtime_rules=%d affinity_runtime_rule_index=%d affinity_runtime_rule_skip=%t", len(setting.Rules), i, rule.SkipRetryOnFailure)
+		}
+	}
+	return fmt.Sprintf("affinity_runtime_rules=%d affinity_runtime_rule=missing", len(setting.Rules))
+}
+
+func channelAffinityOptionRuleDebugString(ruleName string) string {
+	common.OptionMapRWMutex.RLock()
+	raw, ok := common.OptionMap["channel_affinity_setting.rules"]
+	common.OptionMapRWMutex.RUnlock()
+	if !ok {
+		return "affinity_option_rules=missing"
+	}
+
+	var rules []operation_setting.ChannelAffinityRule
+	if err := common.UnmarshalJsonStr(raw, &rules); err != nil {
+		return fmt.Sprintf("affinity_option_rules=parse_error affinity_option_raw_len=%d affinity_option_err=%q", len(raw), err.Error())
+	}
+	for i, rule := range rules {
+		if rule.Name == ruleName {
+			return fmt.Sprintf("affinity_option_rules=%d affinity_option_rule_index=%d affinity_option_rule_skip=%t", len(rules), i, rule.SkipRetryOnFailure)
+		}
+	}
+	return fmt.Sprintf("affinity_option_rules=%d affinity_option_rule=missing", len(rules))
+}
