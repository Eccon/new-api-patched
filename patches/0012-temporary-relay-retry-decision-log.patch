+	}
+	parts := make([]string, 0, len(rules))
+	for i, rule := range rules {
+		parts = append(parts, fmt.Sprintf(
+			"[%d]name=%q skip_retry=%t models=%d paths=%d key_sources=%d include_group=%t include_model=%t include_rule=%t",
+			i,
+			rule.Name,
+			rule.SkipRetryOnFailure,
+			len(rule.ModelRegex),
+			len(rule.PathRegex),
+			len(rule.KeySources),
+			rule.IncludeUsingGroup,
+			rule.IncludeModelName,
+			rule.IncludeRuleName,
+		))
+	}
+	return fmt.Sprintf("count=%d %s", len(rules), strings.Join(parts, "; "))
+}
