diff --git a/relay/channel/openai/helper.go b/relay/channel/openai/helper.go
index 08811a7..f44f59c 100644
--- a/relay/channel/openai/helper.go
+++ b/relay/channel/openai/helper.go
@@ -259,3 +259,41 @@ func sendResponsesStreamData(c *gin.Context, streamResponse dto.ResponsesStreamR
 	}
 	helper.ResponseChunkData(c, streamResponse, data)
 }
+
+func sendResponsesErrorEvent(c *gin.Context, reason string, sequenceNumber int) {
+	payload := struct {
+		Type           string  `json:"type"`
+		SequenceNumber int     `json:"sequence_number"`
+		Code           string  `json:"code"`
+		Message        string  `json:"message"`
+		Param          *string `json:"param"`
+	}{
+		Type:           "error",
+		SequenceNumber: sequenceNumber,
+		Code:           reason,
+		Message:        reason,
+		Param:          nil,
+	}
+
+	if c == nil || c.Writer == nil {
+		return
+	}
+	if c.Request != nil && c.Request.Context().Err() != nil {
+		return
+	}
+
+	jsonData, err := common.Marshal(payload)
+	if err != nil {
+		logger.LogError(c, "failed to marshal responses error event: "+err.Error())
+		return
+	}
+
+	c.Render(-1, common.CustomEvent{Data: "event: error\n"})
+	c.Render(-1, common.CustomEvent{Data: "data: " + string(jsonData)})
+	if err := helper.FlushWriter(c); err != nil {
+		if c != nil && c.Request != nil && c.Request.Context().Err() != nil {
+			return
+		}
+		logger.LogError(c, "failed to send responses error event: "+err.Error())
+	}
+}
