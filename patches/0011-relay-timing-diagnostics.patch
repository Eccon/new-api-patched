+func shouldLogRelayRequestReceived(c *gin.Context) bool {
+	if c == nil || c.Request == nil || c.Request.URL == nil {
+		return false
+	}
+	return isLLMRelayRequestPath(c.Request.URL.Path)
+}
+
+func isLLMRelayRequestPath(path string) bool {
+	return strings.HasPrefix(path, "/v1/chat/completions") ||
+		strings.HasPrefix(path, "/pg/chat/completions") ||
+		strings.HasPrefix(path, "/v1/completions") ||
+		strings.HasPrefix(path, "/v1/messages") ||
+		strings.HasPrefix(path, "/v1/responses") ||
+		isGeminiGenerateRequestPath(path)
+}
+
+func isGeminiGenerateRequestPath(path string) bool {
+	if !strings.HasPrefix(path, "/v1beta/models/") && !strings.HasPrefix(path, "/v1/models/") {
+		return false
+	}
+	return strings.Contains(path, ":generateContent") || strings.Contains(path, ":streamGenerateContent")
+}
+
+func logRelayRequestReceived(c *gin.Context) {
+	ctx := context.Background()
+	path := ""
+	ip := ""
+	if c != nil {
+		if c.Request != nil {
+			ctx = c.Request.Context()
+			ip = c.ClientIP()
+			if c.Request.URL != nil {
+				path = c.Request.URL.Path
+			} else {
+				path = c.Request.RequestURI
+			}
+		}
+	}
+	logger.LogInfo(ctx, fmt.Sprintf("relay request received: path=%s ip=%s", path, ip))
+}
