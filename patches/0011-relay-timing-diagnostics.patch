+func getGinContextTime(c *gin.Context, key string) time.Time {
+	if c == nil {
+		return time.Time{}
+	}
+	if value, exists := c.Get(key); exists {
+		if t, ok := value.(time.Time); ok {
+			return t
+		}
+	}
+	return time.Time{}
+}
+
+func relayTimingSince(start, value time.Time) string {
+	if start.IsZero() || value.IsZero() {
+		return "-"
+	}
+	return fmt.Sprintf("%dms", value.Sub(start).Milliseconds())
+}
+
+func relayTimingDuration(start, end time.Time) string {
+	if start.IsZero() || end.IsZero() {
+		return "-"
+	}
+	return fmt.Sprintf("%dms", end.Sub(start).Milliseconds())
+}
+
+func relayPreflightEnd(t relaycommon.RelayTimingInfo) time.Time {
+	if !t.BillingReady.IsZero() {
+		return t.BillingReady
+	}
+	if !t.PriceReady.IsZero() {
+		return t.PriceReady
+	}
+	if !t.TokensEstimated.IsZero() {
+		return t.TokensEstimated
+	}
+	if !t.SensitiveChecked.IsZero() {
+		return t.SensitiveChecked
+	}
+	if !t.TokenMetaReady.IsZero() {
+		return t.TokenMetaReady
+	}
+	if !t.RelayInfoReady.IsZero() {
+		return t.RelayInfoReady
+	}
+	if !t.RequestValidated.IsZero() {
+		return t.RequestValidated
+	}
+	return t.RelayEnter
+}
