+func appendRequestUserAgentToOther(c *gin.Context, other map[string]interface{}) map[string]interface{} {
+	if c == nil || c.Request == nil {
+		return other
+	}
+	userAgent := strings.TrimSpace(c.Request.UserAgent())
+	if userAgent == "" {
+		return other
+	}
+	userAgent = truncateUserAgent(userAgent)
+	if other == nil {
+		other = make(map[string]interface{})
+	}
+	other["request_user_agent"] = userAgent
+	return other
+}
+
+func truncateUserAgent(userAgent string) string {
+	if len(userAgent) <= maxLoggedUserAgentLength {
+		return userAgent
+	}
+	userAgent = userAgent[:maxLoggedUserAgentLength]
+	for !utf8.ValidString(userAgent) {
+		userAgent = userAgent[:len(userAgent)-1]
+	}
+	return userAgent
+}
